# Copy to .env.atlas (gitignored) and fill in. Used by docker-compose.prod.yml.

# Image tag to pull (matches the pushed registry tag).
ATLAS_VERSION=2026.8.0-rc1

# Postgres
PG_USER=authentik
PG_DB=authentik
PG_PASS=                       # REQUIRED — a strong random password

# authentik secret key (sessions/crypto). Generate: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=          # REQUIRED

# Bind addresses (host side). Behind a reverse proxy, prefer 127.0.0.1.
#   ATLAS_HTTP_BIND=127.0.0.1:9000
#   ATLAS_HTTPS_BIND=127.0.0.1:9443

# ── MCP server ──
# Admin API token for the MCP (claude-mcp service account, or a scoped one).
MCP_AUTHENTIK_TOKEN=           # REQUIRED for the mcp service
# Public ATLAS URL so the MCP returns correct OIDC endpoints, e.g. https://auth.example.com
MCP_AUTHENTIK_URL=http://server:9000
# MCP permission scoping (optional): full access if unset.
ATLAS_MCP_READONLY=false
ATLAS_MCP_ALLOW=
ATLAS_MCP_DENY=
# MCP_BIND=127.0.0.1:9100      # keep localhost-only; expose via the proxy
