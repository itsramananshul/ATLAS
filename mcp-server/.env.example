# Copy to .env and fill in. .env is gitignored.
AUTHENTIK_URL=http://localhost:9000
AUTHENTIK_TOKEN=replace-with-an-authentik-api-token

# Transport: "stdio" for local Claude Code, "http" to host for remote Claude.
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=9100

# ── Permission scoping (optional) — full access by default ──
# Read-only: only read tools; writes + non-GET passthrough are blocked.
ATLAS_MCP_READONLY=false
# Allow-list: if set, ONLY these tools/groups are exposed.
#   groups: read, users, groups, apps, raw    e.g. ATLAS_MCP_ALLOW=read,apps
ATLAS_MCP_ALLOW=
# Deny-list: these tools/groups are removed (applied last).
#   e.g. ATLAS_MCP_DENY=raw,set_user_password
ATLAS_MCP_DENY=
